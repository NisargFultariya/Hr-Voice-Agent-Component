# LiveKit Credentials (used by both services)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
LIVEKIT_AGENT_NAME=hr-recruiter-agent

# LiveKit SIP Configuration (for outbound calls)
LIVEKIT_SIP_TRUNK_ID=sip-trunk-id
SIP_OUTBOUND_CALLER_ID=+919999999999

# LLM Credentials (Groq or OpenRouter)
GROQ_API_KEY=gsk_your_groq_key
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Sarvam AI Credentials (for voice/speech plugin)
SARVAM_API_KEY=your-sarvam-key
SARVAM_TTS_SPEAKER=priya

# Standalone Orchestrator API configuration
HR_API_URL=http://localhost:8080
HR_INTERNAL_SIGNAL_SECRET=supersecretchangeinproduction

# SQLite database storage path
ORCHESTRATOR_DB_PATH=./data/hr_orchestrator.db

# Call timing compliance configurations (in Local Time / IST)
CALL_WINDOW_START=09:00
CALL_WINDOW_END=20:00
